{
  "name": "mcp-outlook-lite",
  "version": "2.0.0",
  "main": "./dist/index.js",
  "type": "module",
  "bin": {
    "mcp-outlook-lite": "./dist/index.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE",
    "SECURITY.md",
    "manifest.json",
    "CLAUDE.md",
    "AGENTS.md"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc",
    "postbuild": "node -e \"const f='dist/index.js',c=require('fs').readFileSync(f,'utf8');if(!c.startsWith('#!'))require('fs').writeFileSync(f,'#!/usr/bin/env node\\n'+c)\"",
    "dev": "tsx server/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:benchmark": "vitest run server/tests/utils/LRUCache.benchmark.js",
    "test:graph": "node server/test/testGraphClient.js",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "outlook",
    "microsoft-graph",
    "email",
    "calendar",
    "sharepoint",
    "ai-agent",
    "claude",
    "cursor",
    "llm"
  ],
  "author": "w21180239",
  "license": "MIT",
  "dependencies": {
    "@microsoft/microsoft-graph-client": "^3.0.7",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "dotenv": "^17.1.0",
    "isomorphic-dompurify": "^2.26.0",
    "node-persist": "^4.0.4",
    "officeparser": "^5.2.0",
    "xlsx": "^0.18.5"
  },
  "optionalDependencies": {
    "keytar": "^7.9.0"
  },
  "description": "The lightest Outlook MCP server — zero secrets, PKCE auth, 46 tools for email, calendar, attachments, SharePoint, and inbox rules",
  "repository": {
    "type": "git",
    "url": "https://github.com/w21180239/mcp-outlook-lite.git"
  },
  "homepage": "https://github.com/w21180239/mcp-outlook-lite#readme",
  "bugs": {
    "url": "https://github.com/w21180239/mcp-outlook-lite/issues"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^3.2.4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
