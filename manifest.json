{
  "dxt_version": "0.1",
  "name": "mcp-outlook-lite",
  "version": "2.0.0",
  "description": "The lightest Outlook MCP server — zero secrets, PKCE auth, 46 tools for email, calendar, attachments, SharePoint, and rules",
  "author": {
    "name": "w21180239"
  },
  "user_config": {
    "azure_client_id": {
      "type": "string",
      "title": "Azure Client ID",
      "description": "Azure Active Directory application (client) ID",
      "required": true
    },
    "azure_tenant_id": {
      "type": "string",
      "title": "Azure Tenant ID", 
      "description": "Azure Active Directory tenant (directory) ID",
      "required": true
    },
    "download_directory": {
      "type": "string",
      "title": "Download Directory",
      "description": "Directory path where email attachments and files will be downloaded. Leave empty to use system temp directory.",
      "required": false,
      "default": ""
    }
  },
  "server": {
    "type": "node",
    "entry_point": "dist/index.js",
    "mcp_config": {
      "command": "node",
      "args": [
        "${__dirname}/dist/index.js"
      ],
      "env": {
        "AZURE_CLIENT_ID": "${user_config.azure_client_id}",
        "AZURE_TENANT_ID": "${user_config.azure_tenant_id}",
        "MCP_OUTLOOK_WORK_DIR": "${user_config.download_directory}"
      }
    }
  },
  "keywords": [
    "outlook",
    "email",
    "calendar",
    "contacts"
  ],
  "license": "MIT"
}
